# Copy to .env for local development. In production these are set as Cloud Run
# environment variables by deploy.sh (except OAUTH_CLIENT_ID, which you paste in
# after creating the OAuth client — see README).

# local | prod
ENV=local

# Auth. Locally it's off by default so you can click around without sign-in.
# Set AUTH_ENABLED=true plus an OAUTH_CLIENT_ID to test the real Google flow.
AUTH_ENABLED=false
OAUTH_CLIENT_ID=
ALLOWED_EMAIL_DOMAIN=createmusicgroup.com
# Optional comma-separated emails allowed regardless of domain.
ALLOWED_EMAILS=

# GCP wiring. Leave BOTH blank for local mode (filesystem storage + JSON DB).
GOOGLE_CLOUD_PROJECT=
GCS_BUCKET=
FIRESTORE_DATABASE=(default)

# Local-mode data directory.
DATA_DIR=.local_data
